{
  "name": "tarasov-negotiation-trainer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src tests && node --check scripts/ingest-methodology.mjs && node --check scripts/seed-harvard-core-atoms.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "npm run lint && npm run typecheck && npm test",
    "methodology:ingest": "node scripts/ingest-methodology.mjs",
    "methodology:extract": "node scripts/ingest-methodology.mjs --extract-atoms",
    "methodology:seed-harvard": "node scripts/seed-harvard-core-atoms.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "mammoth": "^1.12.0",
    "next": "16.2.10",
    "openai": "^6.46.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "unpdf": "^1.6.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.10",
    "fast-xml-parser": "^5.9.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
