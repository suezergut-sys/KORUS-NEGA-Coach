# Секретный ключ используется только серверным маршрутом и никогда не попадает в браузер.
OPENAI_API_KEY=sk-proj-...

# Подключим на следующем этапе, после создания проекта Supabase.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_ANALYSIS_MODEL=gpt-5.4-mini
METHODOLOGY_SOURCE_PATH=private-sources/Tarasov_Iskusstvo-upravlencheskoy-borby.fb2
SITE_PASSWORD=
# Необязательно: если пусто, общая и админская сессии подписываются ADMIN_SESSION_SECRET.
SITE_SESSION_SECRET=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
